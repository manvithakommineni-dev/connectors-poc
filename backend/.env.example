# Salesforce Credentials
# Get these from: Setup > Apps > App Manager > New Connected App
SF_USERNAME=your_salesforce_username@example.com
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_salesforce_security_token
SF_CONSUMER_KEY=your_connected_app_consumer_key
SF_CONSUMER_SECRET=your_connected_app_consumer_secret

# Salesforce instance type: "production" or "sandbox"
SF_DOMAIN=login

# HubSpot
# Get token at: https://app.hubspot.com/private-apps → Create private app → All scopes
HS_ACCESS_TOKEN=your_hubspot_private_app_token

# SAP
# Option 1 (Sandbox - recommended for POC):
#   1. Go to https://api.sap.com and create a FREE account
#   2. Log in → click your avatar (top right) → "Settings" → "Show API Key"
#   3. Copy and paste below
SAP_API_KEY=your_sap_api_key_from_api.sap.com
SAP_BASE_URL=
SAP_AUTH_TYPE=apikey

# Option 2 (On-premise / BTP with Basic Auth):
# SAP_AUTH_TYPE=basic
# SAP_USERNAME=your_sap_username
# SAP_PASSWORD=your_sap_password
# SAP_BASE_URL=https://your-sap-host/sap/opu/odata/sap

# Workato (iPaaS — cross-check connector data via recipes)
# 1. Request trial: https://www.workato.com
# 2. Connect source apps in Workato UI (Salesforce, GA4, etc.)
# 3. Workspace admin → API clients → New client role → enable connections/recipes/jobs endpoints
# 4. Create API client → copy token below
WORKATO_API_TOKEN=your_workato_api_client_token
WORKATO_API_BASE_URL=https://app.trial.workato.com/api

# Pinterest API v5 — FREE Trial access (no payment)
# 1. Pinterest Business account → https://developers.pinterest.com → Connect app → Trial access
# 2. OAuth or trial token with ads_read (+ boards:read, pins:read for organic)
# 3. Ad account ID from Pinterest Ads Manager
PINTEREST_ACCESS_TOKEN=
PINTEREST_AD_ACCOUNT_ID=

# YouTube Data API v3 — FREE (enable in same Google Cloud project as GA4)
# OAuth token with youtube.readonly, or API key for public reads
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_API_KEY=

# Facebook Page (organic) — FREE (create Page + use Meta Developer app)
# Page access token with pages_read_engagement, pages_show_list (NOT the Meta Ads token)
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_API_VERSION=v21.0

# Instagram (organic) — FREE — Business/Creator account linked to Facebook Page
# Can reuse FACEBOOK_PAGE_ACCESS_TOKEN; leave INSTAGRAM_ACCOUNT_ID empty to auto-resolve from Page
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_API_VERSION=v21.0

# Adobe Analytics 2.0 — LIVE requires paid Analytics license (demo works without credentials)
# Adobe Developer Console → OAuth Server-to-Server + Analytics API product profile
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_ACCESS_TOKEN=
ADOBE_GLOBAL_COMPANY_ID=
ADOBE_REPORT_SUITE_ID=
ADOBE_OAUTH_SCOPE=

# App settings
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173"]
