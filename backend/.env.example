# Salesforce Credentials
# Get these from: Setup > Apps > App Manager > New Connected App
SF_USERNAME=your_salesforce_username@example.com
SF_PASSWORD=your_salesforce_password
SF_SECURITY_TOKEN=your_salesforce_security_token
SF_CONSUMER_KEY=your_connected_app_consumer_key
SF_CONSUMER_SECRET=your_connected_app_consumer_secret

# Salesforce instance type: "production" or "sandbox"
SF_DOMAIN=login

# HubSpot
# Get token at: https://app.hubspot.com/private-apps → Create private app → All scopes
HS_ACCESS_TOKEN=your_hubspot_private_app_token

# SAP
# Option 1 (Sandbox - recommended for POC):
#   1. Go to https://api.sap.com and create a FREE account
#   2. Log in → click your avatar (top right) → "Settings" → "Show API Key"
#   3. Copy and paste below
SAP_API_KEY=your_sap_api_key_from_api.sap.com
SAP_BASE_URL=
SAP_AUTH_TYPE=apikey

# Option 2 (On-premise / BTP with Basic Auth):
# SAP_AUTH_TYPE=basic
# SAP_USERNAME=your_sap_username
# SAP_PASSWORD=your_sap_password
# SAP_BASE_URL=https://your-sap-host/sap/opu/odata/sap

# App settings
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173"]
